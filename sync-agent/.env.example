# ACS OS Busy sync settings
# Copy this file to .env, or run: py -3 setup_sync.py

# Company/profile name. Keep code unchanged; create one profile per company.
SYNC_PROFILE=acs

# Current ACS setup:
# BusyWin > Data > comp0004
BUSY_DATA_ROOT=C:\BusyWin\Data
BUSY_COMPANY_CODE=comp0004
BUSY_COMPANY_DIR=C:\BusyWin\Data\comp0004

# Optional override for a server/shared folder later:
# BUSY_COMPANY_DIR=\\MAIN-SERVER\BusyWin\Data\comp0004

# Optional direct database file override. Leave blank when using folder settings.
BUSY_DB_PATH=
BUSY_DB_PASSWORD=

# Supabase (outbound HTTPS from this PC)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Sync interval
POLL_SECONDS=180
